generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model categorias {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome       String     @unique @db.VarChar(100)
  created_at DateTime   @default(now()) @db.Timestamp(6)
  produtos   produtos[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model itens_venda {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venda_id            String            @db.Uuid
  produto_variacao_id String            @db.Uuid
  quantidade          Int
  preco_unitario      Decimal           @db.Decimal(10, 2)
  desconto_percentual Decimal           @default(0) @db.Decimal(5, 2)
  subtotal            Decimal           @db.Decimal(10, 2)
  produto_variacoes   produto_variacoes @relation(fields: [produto_variacao_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_item_variacao")
  vendas              vendas            @relation(fields: [venda_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_item_venda")
}

model marcas {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome       String     @unique @db.VarChar(100)
  created_at DateTime   @default(now()) @db.Timestamp(6)
  produtos   produtos[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model movimentacoes_estoque {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  produto_variacao_id String            @db.Uuid
  usuario_id          String            @db.Uuid
  tipo                String            @db.VarChar(10)
  quantidade          Int
  observacao          String?           @db.VarChar(255)
  created_at          DateTime          @default(now()) @db.Timestamp(6)
  usuarios            usuarios          @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_movimentacao_usuario")
  produto_variacoes   produto_variacoes @relation(fields: [produto_variacao_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_movimentacao_variacao")

  @@index([created_at], map: "idx_movimentacoes_data")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model pagamentos {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venda_id        String   @db.Uuid
  forma_pagamento String   @db.VarChar(20)
  valor           Decimal  @db.Decimal(10, 2)
  parcelas        Int      @default(1)
  created_at      DateTime @default(now()) @db.Timestamp(6)
  vendas          vendas   @relation(fields: [venda_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_pagamento_venda")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model produto_variacoes {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  produto_id            String                  @db.Uuid
  tamanho               String                  @db.VarChar(10)
  quantidade_estoque    Int                     @default(0)
  estoque_minimo        Int                     @default(3)
  created_at            DateTime                @default(now()) @db.Timestamp(6)
  itens_venda           itens_venda[]
  movimentacoes_estoque movimentacoes_estoque[]
  produtos              produtos                @relation(fields: [produto_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_variacao_produto")

  @@unique([produto_id, tamanho], map: "uq_produto_tamanho")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model produtos {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoria_id      String              @db.Uuid
  marca_id          String              @db.Uuid
  nome              String              @db.VarChar(200)
  descricao         String?
  preco             Decimal             @db.Decimal(10, 2)
  ativo             Boolean             @default(true)
  created_at        DateTime            @default(now()) @db.Timestamp(6)
  updated_at        DateTime            @default(now()) @db.Timestamp(6)
  produto_variacoes produto_variacoes[]
  categorias        categorias          @relation(fields: [categoria_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_produto_categoria")
  marcas            marcas              @relation(fields: [marca_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_produto_marca")

  @@index([categoria_id], map: "idx_produtos_categoria")
  @@index([marca_id], map: "idx_produtos_marca")
}

model usuarios {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome                  String                  @db.VarChar(150)
  email                 String                  @unique @db.VarChar(150)
  senha_hash            String                  @db.VarChar(255)
  created_at            DateTime                @default(now()) @db.Timestamp(6)
  updated_at            DateTime                @default(now()) @db.Timestamp(6)
  movimentacoes_estoque movimentacoes_estoque[]
  vendas                vendas[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model vendas {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuario_id     String        @db.Uuid
  valor_bruto    Decimal       @db.Decimal(10, 2)
  valor_desconto Decimal       @default(0) @db.Decimal(10, 2)
  valor_final    Decimal       @db.Decimal(10, 2)
  status         String        @default("FINALIZADA") @db.VarChar(20)
  created_at     DateTime      @default(now()) @db.Timestamp(6)
  itens_venda    itens_venda[]
  pagamentos     pagamentos[]
  usuarios       usuarios      @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_venda_usuario")

  @@index([created_at], map: "idx_vendas_data")
  @@index([usuario_id], map: "idx_vendas_usuario")
}
